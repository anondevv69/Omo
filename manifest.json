{
  "manifest_version": 3,
  "name": "Omo",
  "version": "0.8.0",
  "description": "Omo: wallets from fomo.family and Pump deploys via your relay.",
  "action": {
    "default_title": "Omo",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["storage", "activeTab", "tabs", "scripting"],
  "host_permissions": [
    "https://fomo.family/*",
    "https://www.fomo.family/*",
    "http://localhost/*",
    "http://127.0.0.1/*",
    "https://*.up.railway.app/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://fomo.family/*", "https://www.fomo.family/*"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["inject.js"],
      "matches": ["https://fomo.family/*", "https://www.fomo.family/*"]
    }
  ]
}

